		"prefix": "elements of geometry",
		"body": [
			"namespace geometry {",
			"",
			"using Type = double;",
			"",
			"const Type INF = 1e18;",
			"const Type EPS = 1e-10;",
			"const Type PI = std::acos(-1.0);",
			"",
			"bool equals(const Type &a, const Type &b) { return std::fabs(a - b) < EPS; }",
