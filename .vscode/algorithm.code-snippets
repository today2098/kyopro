			"    for(int i = 1; i <= an; ++i)",
			"        for(int j = 1; j <= bn; ++j) {",
			"            dp[i][j] = std::min({dp[i - 1][j] + 1, dp[i][j - 1] + 1, dp[i - 1][j - 1] + (a[i - 1] == b[j - 1] ? 0 : 1)});",
			"        }",
			"    return dp[an][bn];",
			"}"
		],
