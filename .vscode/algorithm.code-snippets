			"    for(int i = 0; i < n; ++i) ca[i] *= cb[i];",
			"    fft_cooley_tukey(ca, true);",
			"    ca.resize(s);",
			"    std::vector<double> res(s);",
			"    for(int i = 0; i < s; ++i) res[i] = (double)ca[i].real();",
			"    return res;",
