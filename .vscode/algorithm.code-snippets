			"template <typename Type>",
			"std::map<Type, int> prime_factorize(Type n) {  // 素因数分解．O(√N).",
			"    assert(n >= 2);",
			"    std::map<Type, int> mp;  // mp[p]:=(自然数nに含まれる素因数pの個数).",
			"    for(Type p = 2; p * p <= n; ++p) {",
			"        if(n % p != 0) continue;",
			"        while(n % p == 0) n /= p, mp[p]++;",
			"    }",
			"    if(n != 1) mp[n]++;",
			"    return mp;",
			"}"
		],
		"description": "素因数分解"
	},
