			"template <class Class>",
			"int edit_distance(const Class &a, const Class &b) {",
			"    int an = a.size(), bn = b.size();",
			"    std::vector<std::vector<int> > dp(an + 1, std::vector<int>(bn + 1));  // dp[i][j]:=(a[:i]とb[:j]の編集距離).",
