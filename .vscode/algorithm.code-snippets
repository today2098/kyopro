			"        assert(0 <= k and k <= n and n < sz);",
			"        return fact[n] * finv[n - k] % mod * finv[k] % mod;",
			"    }",
			"    int nHk(int n, int k) const { return nCk(k + n - 1, n - 1); }  // 重複組み合わせ．",
			"};",
