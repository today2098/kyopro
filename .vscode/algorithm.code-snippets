		"body": [
			"// 最長共通部分列 (LCS:Longest Common Subsequence)．引数はSTLのシーケンスコンテナ．O(|A|*|B|).",
			"template <class Class>",
			"Class lcs(const Class &a, const Class &b) {",
			"    int an = a.size(), bn = b.size();",
			"    std::vector<std::vector<int> > dp(an + 1, std::vector<int>(bn + 1, 0));  // dp[i][j]:=(a[:i]とb[:j]のLCSの長さ).",
			"    for(int i = 1; i <= an; ++i)",
			"        for(int j = 1; j <= bn; ++j) {",
			"            if(a[i - 1] == b[j - 1])",
			"                dp[i][j] = dp[i - 1][j - 1] + 1;",
			"            else",
			"                dp[i][j] = std::max(dp[i - 1][j], dp[i][j - 1]);",
			"        }",
			"    Class sub(dp[an][bn]);  // sub[]:=(配列a, bのLCS).",
			"    int i = an, j = bn, k = dp[an][bn];",
			"    while(k > 0) {",
			"        if(a[i - 1] == b[j - 1]) {",
			"            sub[k - 1] = a[i - 1];",
			"            i--, j--, k--;",
			"        } else if(dp[i][j] == dp[i - 1][j]) {",
			"            i--;",
			"        } else {",
			"            j--;",
			"        }",
			"    }",
			"    return sub;",
			"}"
		],
		"description": "最長共通部分列 (LCS:Longest Common Subsequence)"
	},
	"lis": {
		"scope": "cpp",
		"prefix": "lis",
		"body": [
			"// 最長増加部分列 (LIS:Longest Increasing Subsequence) の長さを求める．引数はSTLのシーケンスコンテナ．O(|A|*log|A|).",
			"template <class Class>",
			"int lis(const Class &a, bool is_strong = true) {",
			"    Class tmp({a[0]});",
			"    for(int i = 1; i < a.size(); ++i) {",
			"        if(is_strong) {  // 狭義単調増加．",
			"            if(tmp[tmp.size() - 1] < a[i])",
			"                tmp.push_back(a[i]);",
			"            else",
			"                *lower_bound(tmp.begin(), tmp.end(), a[i]) = a[i];",
			"        } else {  // 広義単調増加．",
			"            if(tmp[tmp.size() - 1] <= a[i])",
			"                tmp.push_back(a[i]);",
			"            else",
			"                *upper_bound(tmp.begin(), tmp.end(), a[i]) = a[i];",
			"        }",
			"    }",
			"    return tmp.size();",
			"}"
		],
		"description": "最長増加部分列 (LIS:Longest Increasing Subsequence)"
	},
	"mod_inv": {
		"scope": "cpp",
		"prefix": "mod_inv",
		"body": [
			"long long mod_inv(long long a, int m) {  // 逆元．a^-1 (mod m)を求める（ただし，aとmは互いに素）．O(logA).",
			"    assert(m >= 1);",
			"    long long b = m, u = 1, v = 0;",
			"    while(b) {",
			"        long long t = a / b;",
			"        a -= t * b, u -= t * v;",
			"        std::swap(a, b), std::swap(u, v);",
			"    }",
			"    return u = (u % m + m) % m;",
			"}"
		],
		"description": "逆元"
	},
	"mod_pow": {
		"scope": "cpp",
		"prefix": "mod_pow",
		"body": [
			"long long mod_pow(long long n, long long k, int m) {  // 繰返し二乗法（mod付き）．n^k(mod m)を求める．O(logK).",
			"    assert(k >= 0 and m >= 1);",
			"    n %= m;",
			"    long long res = 1;",
			"    while(k > 0) {",
			"        if(k & 1LL) res = res * n % m;",
			"        n = n * n % m;",
			"        k >>= 1;",
			"    }",
			"    return res;",
			"}"
		],
		"description": "繰返し二乗法（mod付き）"
	},
