			"            tmp = tmp * tmp, k >>= 1;",
			"        }",
			"        return res;",
			"    }",
			"};",
			"",
			"using mint998244353  = Modint<998'244'353>;",
			"using mint1000000007 = Modint<1'000'000'007>;"
